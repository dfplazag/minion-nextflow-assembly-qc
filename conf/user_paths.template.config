/*
  Copy this file to something like:
      conf/user_paths.config
  and replace the placeholder values with your own directories.

  Example run:
      nextflow run main.nf -c conf/user_paths.config
*/

params {
  // Replace with the FASTQ or FASTQ.GZ glob you want to analyse.
  input  = '<PATH_TO_PROJECT_WORKDIR>/data/*.fastq.gz'

  // Replace with the full path to your reference FASTA.
  // Example: BL21_reference.fasta for the validated control use case.
  ref    = '<PATH_TO_PROJECT_WORKDIR>/refs/BL21_reference.fasta'

  // Replace with where you want published results to go.
  outdir = '<PATH_TO_PROJECT_WORKDIR>/results'
}
